{
    "compilerOptions": {
        "target": "ES6",
        "outDir": "./build/",
        "rootDir": "./src",
        "module": "commonjs",
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "esModuleInterop": true
    }
}